{
  "name": "@sm-bot/logging",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "tsc -p tsconfig.json && node --test dist/src/domain/realtime-policy.test.js dist/src/application/log-stream.test.js dist/src/application/log-writer.test.js dist/src/discord/message-events.test.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@sm-bot/db": "workspace:*",
    "@sm-bot/shared": "workspace:*",
    "discord.js": "^14.27.0"
  },
  "devDependencies": {
    "typescript": "^7.0.2"
  }
}
